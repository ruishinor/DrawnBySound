# Store text files with LF endings consistently.
* text=auto eol=lf

# Windows command files require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicit binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.wav binary
*.mp3 binary
*.ogg binary
